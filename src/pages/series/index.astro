---
import { getSeriesMeta } from "@constants/series";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSeriesList, getSeriesPosts } from "@utils/content-utils";
import { url } from "@utils/url-utils";

const slugs = await getSeriesList();
const series = await Promise.all(
	slugs.map(async (slug) => {
		const posts = await getSeriesPosts(slug);
		return { slug, meta: getSeriesMeta(slug), count: posts.length };
	}),
);
// Show the series with the most articles first; stable by name otherwise.
series.sort(
	(a, b) => b.count - a.count || a.meta.name.localeCompare(b.meta.name),
);
---

<MainGridLayout title="Series" description="Article series on this site.">
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-6 md:px-9 py-6 relative w-full">
            <h1 class="text-3xl font-bold text-black/90 dark:text-white/90 mb-6">Series</h1>

            {series.length === 0 && (
                <p class="text-black/50 dark:text-white/50">No series yet.</p>
            )}

            <ul class="flex flex-col gap-3">
                {series.map((s) => (
                    <li class="transition rounded-[var(--radius-large)] bg-black/[0.02] dark:bg-white/[0.04] hover:bg-[var(--btn-plain-bg-hover)]">
                        <a href={url(`/series/${s.slug}/`)} class="block px-5 py-4">
                            <span class="flex items-baseline gap-3 flex-wrap">
                                <span class="text-lg font-medium text-black/90 dark:text-white/90">
                                    {s.meta.name}
                                </span>
                                <span class="text-sm text-black/40 dark:text-white/40 tabular-nums">
                                    {s.count} {s.count === 1 ? "article" : "articles"}
                                </span>
                            </span>
                            {s.meta.subtitle && (
                                <span class="block text-sm text-black/50 dark:text-white/50 mt-1">
                                    {s.meta.subtitle}
                                </span>
                            )}
                        </a>
                    </li>
                ))}
            </ul>
        </div>
    </div>
</MainGridLayout>
